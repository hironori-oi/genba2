# GENBA Phase 1 environment variables (names only — values are owner-managed via SOPS+age)
# See config/tech-stack.yaml. Decrypt via ./scripts/secrets-decrypt.sh to populate .env.local before `npm run dev`.

# Supabase (owner creates the project and registers these into .env.enc)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to client bundles. Used by Edge Functions / server actions
# for tenant_admin role-change RPC (refresh-token revoke) and admin migrations only.
SUPABASE_SERVICE_ROLE_KEY=

# Default URL for redirect/callback flows in local dev. Production replaces this in Vercel env.
NEXT_PUBLIC_APP_URL=http://localhost:3000
